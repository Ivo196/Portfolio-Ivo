---
import ForecastVisual from './ForecastVisual.astro';
import { portfolio } from '../data/portfolio';

const hasCv = Boolean(portfolio.links.cv);
---

<section class="hero-section wrapper" aria-labelledby="hero-title">
	<div class="hero-copy">
		<p class="eyebrow">{portfolio.name}</p>
		<p class="role">{portfolio.title}</p>
		<p class="focus">{portfolio.focus}</p>
		<h1 id="hero-title">Building forecasting and decision systems for energy markets.</h1>
		<p class="summary">
			I work at the intersection of machine learning, quantitative research, and power systems —
			turning market, weather, and operational data into validated forecasts and risk-aware decisions.
		</p>
		<p class="bio">{portfolio.heroDescription}</p>
		<p class="availability">{portfolio.availability}</p>
		<div class="actions" aria-label="Primary actions">
			<a class="button primary" href="#work">View flagship project</a>
			<a class="button" href={portfolio.links.github} target="_blank" rel="noreferrer">GitHub</a>
			<a class="button" href={portfolio.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
			{hasCv && <a class="button quiet" href={portfolio.links.cv} download>Download CV</a>}
		</div>
	</div>
	<div class="hero-panel">
		<ForecastVisual />
	</div>
</section>

<style>
	.hero-section {
		display: grid;
		gap: 2rem;
		align-items: center;
		padding-block: 2.5rem 3.25rem;
	}

	.hero-copy {
		max-width: 56rem;
	}

	.eyebrow,
	.role,
	.focus,
	.availability {
		font-family: var(--font-mono);
	}

	.eyebrow {
		margin-bottom: 0.8rem;
		color: var(--text);
		font-size: clamp(1.35rem, 3vw, 2rem);
		font-weight: 700;
	}

	.role {
		color: var(--cyan);
		font-size: 0.92rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.focus {
		margin-top: 0.4rem;
		color: var(--muted);
		font-size: 0.9rem;
	}

	h1 {
		max-width: 52rem;
		margin-top: 1.35rem;
		color: var(--text);
		font-size: clamp(2.85rem, 5.7vw, 4.7rem);
		font-weight: 800;
		letter-spacing: 0;
		line-height: 0.94;
	}

	.summary {
		max-width: 48rem;
		margin-top: 1.6rem;
		color: var(--text-soft);
		font-size: clamp(1.08rem, 2vw, 1.35rem);
		line-height: 1.65;
	}

	.bio {
		max-width: 48rem;
		margin-top: 1rem;
		color: var(--muted);
	}

	.availability {
		margin-top: 1.1rem;
		color: var(--text-soft);
		font-size: 0.88rem;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.hero-panel {
		align-self: end;
	}

	@media (min-width: 62em) {
		.hero-section {
			grid-template-columns: minmax(0, 1.1fr) minmax(22rem, 0.72fr);
			padding-block: 2.4rem 3.5rem;
		}

		.hero-panel {
			transform: translateY(2rem);
		}
	}
</style>
