---
import { portfolio } from '../data/portfolio';
---

<section class="section wrapper selected-work" aria-labelledby="selected-work-title">
	<div class="section-kicker">Selected work</div>
	<div class="section-heading">
		<h2 id="selected-work-title">Focused forecasting and infrastructure work</h2>
	</div>

	<div class="project-grid">
		{
			portfolio.selectedWork.map((project) => (
				<article class="project-card">
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<ul aria-label={`${project.title} tags`}>
						{project.tags.map((tag) => (
							<li>{tag}</li>
						))}
					</ul>
				</article>
			))
		}
	</div>
</section>

<style>
	.section {
		padding-block: 4rem 5.5rem;
	}

	.section-heading {
		margin-top: 0.8rem;
	}

	.project-grid {
		display: grid;
		gap: 1rem;
		margin-top: 2rem;
	}

	.project-card {
		display: grid;
		gap: 1rem;
		padding: 1.2rem;
		border: 1px solid var(--border);
		border-radius: 1rem;
		background: var(--surface);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease;
	}

	.project-card:hover {
		transform: translateY(-3px);
		border-color: rgba(57, 213, 255, 0.42);
		background: var(--surface-strong);
	}

	h3 {
		color: var(--text);
		font-size: 1.25rem;
	}

	p {
		color: var(--muted);
	}

	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		padding: 0.35rem 0.55rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--text-soft);
		font-family: var(--font-mono);
		font-size: 0.75rem;
	}

	@media (min-width: 48em) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.project-card {
			transition: none;
		}

		.project-card:hover {
			transform: none;
		}
	}
</style>
