---
import { existsSync } from 'node:fs';
import { portfolio } from '../data/portfolio';

const cvPath = new URL('../../public/assets/resume.pdf', import.meta.url);
const hasCv = existsSync(cvPath);
---

<header class="site-header">
	<a class="brand" href="/" aria-label="Ivo Tonioni home">
		<span aria-hidden="true"></span>
		<span>Ivo Tonioni</span>
	</a>

	<nav class="nav-pill" aria-label="Main navigation">
		{portfolio.nav.map((item) => <a href={item.href}>{item.label}</a>)}
	</nav>

	<div class="nav-actions" aria-label="Profile links">
		<a href={portfolio.links.github} target="_blank" rel="noreferrer">GitHub</a>
		<a href={portfolio.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
		<a href={portfolio.links.email}>Email</a>
		{hasCv && <a class="cv-link" href={portfolio.links.cv} download>CV</a>}
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		align-items: center;
		width: min(100% - 1rem, 82rem);
		margin-inline: auto;
		padding-block: 0.75rem;
		backdrop-filter: blur(18px);
	}

	.brand,
	.nav-actions a,
	.nav-pill a {
		color: var(--text-soft);
		text-decoration: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		width: max-content;
		font-family: var(--font-mono);
		font-size: 0.86rem;
	}

	.brand span:first-child {
		width: 0.65rem;
		height: 0.65rem;
		border-radius: 999px;
		background: var(--cyan);
		box-shadow: 0 0 22px rgba(57, 213, 255, 0.8);
	}

	.nav-pill,
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		width: max-content;
		max-width: 100%;
		padding: 0.35rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: rgba(8, 11, 17, 0.78);
		box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
		overflow-x: auto;
		scrollbar-width: none;
	}

	.nav-pill::-webkit-scrollbar,
	.nav-actions::-webkit-scrollbar {
		display: none;
	}

	.nav-pill a,
	.nav-actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2rem;
		padding: 0.45rem 0.72rem;
		border-radius: 999px;
		font-size: 0.82rem;
		white-space: nowrap;
		transition:
			color 160ms ease,
			background-color 160ms ease;
	}

	.nav-pill a:hover,
	.nav-actions a:hover,
	.nav-pill a:focus-visible,
	.nav-actions a:focus-visible {
		color: var(--text);
		background: rgba(255, 255, 255, 0.06);
	}

	.nav-actions {
		display: none;
		justify-self: end;
		font-family: var(--font-mono);
	}

	.cv-link {
		color: var(--bg) !important;
		background: var(--text);
	}

	@media (min-width: 46em) {
		.site-header {
			grid-template-columns: 1fr auto;
		}

		.nav-pill {
			justify-self: end;
		}
	}

	@media (min-width: 68em) {
		.site-header {
			grid-template-columns: 1fr auto 1fr;
			width: min(100% - 2rem, 82rem);
		}

		.nav-pill {
			justify-self: center;
		}

		.nav-actions {
			display: flex;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-pill a,
		.nav-actions a {
			transition: none;
		}
	}
</style>
